# fake = deterministische Offline-Provider (kein Key nötig) | openai = OpenAI + Pinecone
SOURCERER_PROVIDERS=fake

# Nur bei SOURCERER_PROVIDERS=openai nötig:
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=sourcerer

# Optional (Defaults siehe app/config.py):
# SOURCERER_CHUNK_SIZE=800
# SOURCERER_CHUNK_OVERLAP=120
# SOURCERER_TOP_K=6
# SOURCERER_MAX_UPLOAD_BYTES=10485760
# SOURCERER_CORS_ORIGINS=http://localhost:3000
